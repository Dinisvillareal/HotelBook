<file path="src/pages/Login.css">
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

.login-page{

    width:100%;
    height:100vh;

    background:url("https://images.unsplash.com/photo-1566073771259-6a8506099945?q=80&w=1974")
        center center/cover no-repeat;

    display:flex;
    justify-content:center;
    align-items:center;
}

.overlay{

    width:100%;
    height:100%;

    background:rgba(15,23,42,.65);

    display:flex;
    justify-content:center;
    align-items:center;
}

.login-card{

    width:420px;

    padding:45px;

    border-radius:24px;

    backdrop-filter:blur(18px);

    background:rgba(255,255,255,.15);

    border:1px solid rgba(255,255,255,.25);

    color:white;

    box-shadow:0 25px 60px rgba(0,0,0,.3);

    animation:fadeUp .7s;
}

.logo{

    font-size:45px;

    text-align:center;

    color:#60a5fa;

    margin-bottom:15px;
}

.login-card h1{

    text-align:center;

    margin-bottom:8px;
}

.login-card p{

    text-align:center;

    opacity:.8;

    margin-bottom:30px;
}

.input-group{

    position:relative;

    margin-bottom:20px;
}

.icon{

    position:absolute;

    left:18px;

    top:50%;

    transform:translateY(-50%);

    color:#94a3b8;
}

.input-group input{

    width:100%;

    padding:15px 50px;

    border:none;

    border-radius:12px;

    outline:none;

    font-size:15px;

    transition:.3s;
}

.input-group input:focus{

    box-shadow:0 0 0 3px #3b82f6;
}

.eye-btn{

    position:absolute;

    right:15px;

    top:50%;

    transform:translateY(-50%);

    background:none;

    border:none;

    color:#64748b;

    cursor:pointer;

    font-size:18px;
}

.login-btn{

    width:100%;

    padding:15px;

    border:none;

    border-radius:12px;

    background:#2563eb;

    color:white;

    font-size:16px;

    font-weight:600;

    cursor:pointer;

    transition:.3s;
}

.login-btn:hover{

    background:#1d4ed8;

    transform:translateY(-2px);
}

.login-btn:disabled{

    background:#64748b;

    cursor:not-allowed;
}

.register-link{

    margin-top:25px;

    text-align:center;
}

.register-link a{

    color:#60a5fa;

    text-decoration:none;

    font-weight:bold;

    margin-left:5px;
}

.error{

    background:#ef4444;

    padding:12px;

    border-radius:10px;

    margin-bottom:20px;

    text-align:center;
}

@keyframes fadeUp{

from{

opacity:0;

transform:translateY(40px);

}

to{

opacity:1;

transform:translateY(0);

}

}
</file>

<file path="src/pages/Register.css">
@import "./Login.css";

.register-page {
  width: 100%;
  min-height: 100vh;
  background: url("/images/login-bg.jpg") center center/cover no-repeat;
  display: flex;
  justify-content: center;
  align-items: center;
}

.register-card {
  width: 460px;
  padding: 45px;
  border-radius: 24px;
  backdrop-filter: blur(18px);
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid rgba(255, 255, 255, 0.25);
  color: white;
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
}

.register-btn {
  width: 100%;
  margin-top: 20px;
  padding: 15px;
  border: none;
  border-radius: 12px;
  background: #16a34a;
  color: white;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.register-btn:hover {
  background: #15803d;
  transform: translateY(-2px);
}

.register-btn:disabled {
  background: #64748b;
  cursor: not-allowed;
}

.success {
  background: rgba(34, 197, 94, 0.18);
  color: #dcfce7;
  border: 1px solid rgba(34, 197, 94, 0.35);
  padding: 12px;
  border-radius: 10px;
  margin-bottom: 20px;
  text-align: center;
}

.strength {
  margin-top: -8px;
  margin-bottom: 12px;
  font-size: 14px;
  font-weight: 600;
}

.strength.weak {
  color: #f87171;
}

.strength.medium {
  color: #fbbf24;
}

.strength.strong {
  color: #4ade80;
}

.login-link {
  text-align: center;
  margin-top: 24px;
}

.login-link a {
  margin-left: 6px;
  color: #60a5fa;
  text-decoration: none;
  font-weight: 600;
}
